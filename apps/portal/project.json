{
  "name": "portal",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "app",
  "sourceRoot": "apps/portal/src",
  "tags": ["scope:portal"],
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/portal",
        "browser": "apps/portal/src/main.ts",
        "polyfills": ["zone.js"],
        "tsConfig": "apps/portal/tsconfig.app.json",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/portal/public"
          }
        ],
        "styles": ["apps/portal/src/styles.css"],
        "ssr": false,
        "budgets": [
          {
            "type": "anyComponentStyle",
            "maximumWarning": "50kb",
            "maximumError": "100kb"
          }
        ]
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "1mb"
            },
            {
              "type": "anyStyle",
              "maximumWarning": "50kb",
              "maximumError": "100kb"
            }
          ],
          "outputHashing": "all",
          "prerender": false
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "dependsOn": [],
      "continuous": true,
      "executor": "@angular/build:dev-server",
      "configurations": {
        "production": {
          "buildTarget": "portal:build:production"
        },
        "development": {
          "buildTarget": "portal:build:development"
        }
      },
      "defaultConfiguration": "development",
      "options": {
        "proxyConfig": "apps/portal/proxy.conf.json"
      }
    },
    "extract-i18n": {
      "executor": "@angular/build:extract-i18n",
      "options": {
        "buildTarget": "portal:build"
      }
    },
    "serve-static": {
      "continuous": true,
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "portal:build",
        "port": 4200,
        "staticFilePath": "dist/apps/portal/browser",
        "spa": true
      }
    }
  }
}
