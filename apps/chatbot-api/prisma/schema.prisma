generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [postgis]
}

model Mine {
  id        String                   @id @default(uuid()) @db.Uuid
  name      String
  geom      Unsupported("geometry")?
  createdAt DateTime                 @default(now()) @map("created_at")
  clusters  Cluster[]
  missions  DrillMission[]

  @@map("Mine")
}

model Cluster {
  id        String                   @id @default(uuid()) @db.Uuid
  stoneType String                   @map("stone_type")
  quantity  Float
  geom      Unsupported("geometry")?
  mineId    String                   @map("mine_id") @db.Uuid
  createdAt DateTime                 @default(now()) @map("created_at")
  mine      Mine                     @relation(fields: [mineId], references: [id])
  missions  DrillMission[]

  @@map("Cluster")
}

model Drill {
  id                  String         @id @default(uuid()) @db.Uuid
  name                String
  supportedStoneTypes String[]       @map("supported_stone_types")
  createdAt           DateTime       @default(now()) @map("created_at")
  missions            DrillMission[]

  @@map("Drill")
}

model DrillMission {
  id        String   @id @default(uuid()) @db.Uuid
  mineId    String   @map("mine_id") @db.Uuid
  drillId   String   @map("drill_id") @db.Uuid
  clusterId String?  @map("cluster_id") @db.Uuid
  stoneType String   @map("stone_type")
  date      DateTime
  createdAt DateTime @default(now()) @map("created_at")
  drill     Drill    @relation(fields: [drillId], references: [id])
  mine      Mine     @relation(fields: [mineId], references: [id])
  cluster   Cluster? @relation(fields: [clusterId], references: [id])

  @@map("DrillMission")
}

model SavedQuery {
  id        String   @id @default(uuid()) @db.Uuid
  name      String?
  query     Json
  sql       String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("SavedQuery")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model spatial_ref_sys {
  srid      Int     @id
  auth_name String? @db.VarChar(256)
  auth_srid Int?
  srtext    String? @db.VarChar(2048)
  proj4text String? @db.VarChar(2048)
}
