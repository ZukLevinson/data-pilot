generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [postgis]
}

model Mine {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  // Geographic boundary (Polygon)
  geom      Unsupported("geometry(Polygon, 4326)")?
  createdAt DateTime @default(now()) @map("created_at")
  
  clusters  Cluster[]
  missions  DrillMission[]

  @@map("Mine")
}

model Cluster {
  id        String   @id @default(uuid()) @db.Uuid
  stoneType String   @map("stone_type")
  quantity  Float
  // Geographic location (Point)
  geom      Unsupported("geometry(Point, 4326)")?
  
  mineId    String   @db.Uuid @map("mine_id")
  mine      Mine     @relation(fields: [mineId], references: [id])
  
  createdAt DateTime @default(now()) @map("created_at")

  @@map("Cluster")
}

model Drill {
  id                 String   @id @default(uuid()) @db.Uuid
  name               String
  supportedStoneTypes String[] @map("supported_stone_types")
  
  createdAt          DateTime @default(now()) @map("created_at")
  missions           DrillMission[]

  @@map("Drill")
}

model DrillMission {
  id        String   @id @default(uuid()) @db.Uuid
  
  mineId    String   @db.Uuid @map("mine_id")
  mine      Mine     @relation(fields: [mineId], references: [id])
  
  drillId   String   @db.Uuid @map("drill_id")
  drill     Drill    @relation(fields: [drillId], references: [id])
  
  stoneType String   @map("stone_type")
  date      DateTime
  
  createdAt DateTime @default(now()) @map("created_at")

  @@map("DrillMission")
}

model SavedQuery {
  id        String   @id @default(uuid()) @db.Uuid
  name      String?
  query     Json     // Stored query structure (JSON)
  sql       String?  // The generated SQL string for transparency
  createdAt DateTime @default(now()) @map("created_at")

  @@map("SavedQuery")
}
