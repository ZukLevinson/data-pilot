generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  output          = "../../../node_modules/.prisma/client"
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

model User {
  id    String    @id @default(uuid()) @db.Uuid
  email String    @unique
  tags  UserTag[]
}

model Tag {
  id       String      @id @default(uuid()) @db.Uuid
  name     String      @unique
  users    UserTag[]
  entities EntityTag[]
}

model UserTag {
  userId String @map("user_id") @db.Uuid
  tagId  String @map("tag_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([userId, tagId])
}

model Entity {
  id        String                  @id @default(uuid()) @db.Uuid
  content   String
  type      String
  // Using pgvector's vector type, assuming 1536 dimensions (e.g., from an embedding model, Qwen usually 4096 or 1536 depending on the embedding model used, let's use unsupported("vector") for custom dimensions or Prisma's native support if available)
  // Currently Prisma supports Unsupported("vector(1536)")
  embedding Unsupported("vector(768)")?
  tags      EntityTag[]
}

model EntityTag {
  entityId String @map("entity_id") @db.Uuid
  tagId    String @map("tag_id") @db.Uuid
  entity   Entity @relation(fields: [entityId], references: [id], onDelete: Cascade)
  tag      Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([entityId, tagId])
}
